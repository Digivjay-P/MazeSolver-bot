module encoder(clk_50M, quadA, quadB, reset, count);

input clk_50M, quadA, quadB, reset;

output reg	 [24:0] count;



reg quadA_delayed, quadB_delayed;

always @(posedge clk_50M) quadA_delayed <= quadA;

always @(posedge clk_50M) quadB_delayed <= quadB;



wire count_enable = quadA ^ quadA_delayed ^ quadB ^ quadB_delayed;

wire count_direction = quadA ^ quadB_delayed;




always @(posedge clk_50M or negedge reset)
begin
	if(!reset) count<=0;
	
  else begin
		if(count_enable) begin
			if(count_direction) count<=count+1; else count<=count-1;
		end
	end
end



endmodule
